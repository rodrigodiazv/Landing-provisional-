{
  "version": 2,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
  "buildCommand": "echo 'Static HTML site'",
  "outputDirectory": "."
}
